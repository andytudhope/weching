{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2020",
    "outDir": ".tmp-tests",
    "noEmit": false,
    "declaration": false,
    "incremental": false,
    "plugins": []
  },
  "include": [
    "src/lib/*.ts",
    "src/types/**/*.ts"
  ]
}
